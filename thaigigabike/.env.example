# ── Site ───────────────────────────────────────────────────
# Public canonical origin (no trailing slash). Used for metadataBase,
# sitemap.xml, robots.txt and Open Graph URLs. Falls back to localhost in dev.
NEXT_PUBLIC_SITE_URL=https://www.thaigigabike.com

# ── Supabase ───────────────────────────────────────────────
# Public (safe to expose to the browser). Find these in your Supabase
# project: Settings → API. The anon key is shipped to the browser by design.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# SERVER ONLY — never prefix with NEXT_PUBLIC_, never expose to the browser,
# never commit the real value. Used by API routes (createServiceClient) to
# bypass RLS for trusted operations. Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Custom Auth ────────────────────────────────────────────
# Session cookie name (default: tgb_session). Change only if you need to
# isolate sessions between environments.
CUSTOM_AUTH_SESSION_COOKIE=tgb_session

# Session lifetime in days (default: 14).
CUSTOM_AUTH_SESSION_DAYS=14

# One-time secret for bootstrapping the first owner account via POST /api/admin/setup-owner.
# MUST be changed from the default before use; set to something random in production.
ADMIN_SETUP_SECRET=change-me-in-local-env

# ── Email — Order lookup OTP (P0-B4) ────────────────────────
# Provider: Resend (https://resend.com) — no SDK needed, direct fetch.
# Without this in production, OTPs are generated but never delivered.
# In development (NODE_ENV !== 'production'), OTP is logged to console instead.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=orders@yourdomain.com
