# ── Supabase ───────────────────────────────────────────────
# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER ONLY — never prefix with NEXT_PUBLIC_, never expose to the browser.
# Used by API routes (createServiceClient) to bypass RLS for trusted operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin authorization (OWASP A01) ────────────────────────
# Comma-separated allowlist of admin emails. A logged-in Supabase user is only
# treated as an admin if their email is listed here. If empty, NOBODY is admin
# (fail closed). Server-only.
ADMIN_EMAILS=admin@example.com

# ── Email — Order lookup OTP (P0-B4) ────────────────────────
# Provider: Resend (https://resend.com) — no SDK needed, direct fetch.
# Without this in production, OTPs are generated but never delivered.
# In development (NODE_ENV !== 'production'), OTP is logged to console instead.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=orders@yourdomain.com
